# =============================================================================
# real-estate-api — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for local development:
#   cp .env.example .env
#
# For Docker Compose, see the top-level .env file.
# =============================================================================

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT_SECONDS=2
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_HEALTH_CHECK_FAILURE_THRESHOLD=3

# ---------------------------------------------------------------------------
# PostgreSQL (asyncpg DSN)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/realestate
DB_POOL_SIZE=5

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
CACHE_TTL_SECONDS=120
CACHE_KEY_PREFIX=properties:list:v1

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_PREFIX=/api/v1
PROPERTIES_MAX_LIMIT=100
PROPERTIES_DEFAULT_LIMIT=20

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
METRICS_ENABLED=true
