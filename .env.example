# =============================================================================
# Real Estate Aggregation Platform — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to git — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=realestate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_MAXMEMORY=1gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Monitoring (Prometheus + Alertmanager)
# ---------------------------------------------------------------------------
PUSHGATEWAY_PORT=9091
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
ALERTMANAGER_PORT=9093

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/realestate
REDIS_URL=redis://localhost:6379/0
# ^ Used by scrapper-base for cache invalidation and by real-estate-api for cache-aside.
#   If unset/empty, cache invalidation is silently skipped.
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=change-me
# MINIO_BUCKET=property-photos
# PUSHGATEWAY_URL=http://pushgateway:9091
