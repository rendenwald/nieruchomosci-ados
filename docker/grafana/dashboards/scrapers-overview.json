{
  "__inputs": [],
  "__requires": [],
  "title": "Scrapers Overview",
  "uid": "scrapers-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["scrapers", "metrics"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Listings Scraped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["last", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(listings_scraped_total[5m])",
          "legendFormat": "{{portal}}",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Scrape Duration (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["last", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(scrape_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, rate(scrape_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, rate(scrape_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate per Portal",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "calcs": ["last", "max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(scrape_errors_total[15m]) / (rate(listings_scraped_total[15m]) > 0 or 1) * 100",
          "legendFormat": "{{portal}}",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Time Since Last Scraper Run",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 43200 },
              { "color": "red", "value": 86400 }
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 3600,
                "result": { "text": "Just now", "color": "green" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 3600,
                "to": 43200,
                "result": { "text": "{{__value__}} ago", "color": "yellow" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 43200,
                "to": 86400,
                "result": { "text": "{{__value__}} ago", "color": "orange" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 86400,
                "to": null,
                "result": { "text": "MORE THAN 24h AGO", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - scraper_last_run_timestamp",
          "legendFormat": "{{portal}}",
          "interval": "",
          "intervalFactor": 1,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    }
  ]
}
